{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run lint)",
      "Bash(npm run seed)",
      "Bash(npm run start:dev)",
      "Bash(npm run start:prod)",
      "Bash(docker compose up *)",
      "Bash(docker compose down *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git branch *)",
      "Bash(git remote *)"
    ],
    "deny": [
      "Read(./backend/.env)",
      "Read(./frontend/.env.local)"
    ]
  }
}
