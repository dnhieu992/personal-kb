# MySQL connection.
# Option A (no Docker): reuse the host MySQL on 3306 with a separate database:
DATABASE_URL=mysql://pkb:pkbpass@127.0.0.1:3306/personal_kb
# Option B (Docker): docker-compose maps MySQL to host port 3307 (see docker-compose.yml):
# DATABASE_URL=mysql://pkb:pkbpass@127.0.0.1:3307/personal_kb

# Anthropic Claude API key (required only for AI features)
ANTHROPIC_API_KEY=

# Qdrant vector DB (required only for semantic search / chat)
QDRANT_URL=http://localhost:6333

# Backend HTTP port (4001 to avoid market-analysis on 3000/3001)
PORT=4001

# Allowed origin for CORS (the frontend)
FRONTEND_URL=http://localhost:4000
